# Copy to .env and fill in values (never commit .env)

# Required — MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ai_project?retryWrites=true&w=majority
MONGODB_DB_NAME=ai_project

# Required — GitHub Models token (Settings → Developer settings → Personal access tokens)
GITHUB_TOKEN=ghp_your_token_here

# Auth — use the SAME value as Render → nova-ai-api → JWT_SECRET_KEY
JWT_SECRET_KEY=change-this-to-a-long-random-string

# Optional — Google Sign-In (same Web Client ID on backend + frontend build)
# In Google Cloud Console → Credentials → OAuth 2.0 Client IDs → Web client:
#   Authorized JavaScript origins (NOT redirect URIs for this flow):
#     http://localhost:3000
#     https://nova-ai-frontend.onrender.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
REACT_APP_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Admin — comma-separated emails that can open /admin dashboard
ADMIN_EMAILS=shweta@gmail.com

# CORS — production frontend + regex for other Render preview URLs
CORS_ORIGINS=https://nova-ai-frontend.onrender.com
CORS_ORIGIN_REGEX=https://.*\.onrender\.com

# RAG / optional services (disable on Render free tier unless you add Redis/Neo4j)
NEO4J_ENABLED=false
RAG_USE_REDIS=false
ALLOW_MODEL_DOWNLOAD=1

# Neo4j (only if NEO4J_ENABLED=true)
# NEO4J_URI=neo4j+s://xxx.databases.neo4j.io
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Redis (only if RAG_USE_REDIS=true)
# REDIS_URL=redis://...
